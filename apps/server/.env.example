# Telegram API credentials from https://my.telegram.org (API development tools)
API_ID=
API_HASH=

# 32-byte hex key for AES-256-GCM session encryption at rest.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENC_KEY=

# Secret for signing the app session (JWT) cookie.
# Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Server port
PORT=4000

# Allowed browser origin (the Next.js app) for CORS + cookies
WEB_ORIGIN=http://localhost:3000

# Where downloaded media is cached on disk
MEDIA_CACHE_DIR=./.cache/media

# Where the SQLite database file lives
DATA_DIR=./data
