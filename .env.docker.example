# Docker Compose configuration for Aerogram.
# Copy to `.env` in this directory (docker compose loads it automatically):
#   cp .env.docker.example .env

# Telegram API credentials from https://my.telegram.org
API_ID=
API_HASH=

# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENC_KEY=
# Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Public URL the BROWSER uses to reach the backend (baked into the web bundle at build time).
# Local: http://localhost:4000 — Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# The browser origin of the web app (for CORS + cookies).
# Local: http://localhost:3000 — Production: https://your-domain.com
WEB_ORIGIN=http://localhost:3000
